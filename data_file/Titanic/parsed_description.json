  },
  "SibSp": {
    "description": "Number of siblings or spouses aboard",
    "type": "numerical"
  },
  "Parch": {
    "description": "Number of parents or children aboard",
    "type": "numerical"
  },
  "Ticket": {
    "description": "Ticket number (681 unique values)",
    "type": "text"
  },
  "Fare": {
    "description": "Passenger fare",
    "type": "numerical"
  },
  "Cabin": {
    "description": "Cabin number (many missing values)",
    "type": "text"
  },
  "Embarked": {
