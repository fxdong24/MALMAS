  },
  "Pclass": {
    "description": "Ticket class (1 = 1st, 2 = 2nd, 3 = 3rd)",
    "type": "categorical"
  },
  "Name": {
    "description": "Passenger's name (891 unique values)",
    "type": "text"
  },
  "Sex": {
    "description": "Gender of the passenger (male, female)",
